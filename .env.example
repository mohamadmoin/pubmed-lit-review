# LitReview — PubMed AI Literature Review
# Copy to .env and fill in values before: docker compose up -d --build

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
# Open-source default: allow guest/demo access without registering (set False in production)
LITREVIEW_DEMO_MODE=True
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# LLM provider: lmstudio (local) or openai (cloud)
LLM_PROVIDER=lmstudio
LLM_TEMPERATURE=0.7

# LM Studio — OpenAI-compatible local server (default)
# Start LM Studio and load a model; default server is http://127.0.0.1:1234
LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
LM_STUDIO_MODEL=google/gemma-4-12b
LM_STUDIO_MAX_TOKENS=8192
LM_STUDIO_CONTEXT_TOKENS=16000
LM_STUDIO_API_KEY=lm-studio

# OpenAI — set LLM_PROVIDER=openai to use
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# PubMed / NCBI Entrez — email is REQUIRED by NCBI usage policy
# Register: https://www.ncbi.nlm.nih.gov/account/settings/
PUBMED_EMAIL=your.email@example.com
PUBMED_API_KEY=
PUBMED_TOOL=LitReview

# Neo4j (must match docker-compose NEO4J_AUTH password)
NEO4J_PASSWORD=your_password
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Storage (inside containers)
TEXT_STORAGE_PATH=/app/data/text_storage

# CORS (only needed when Flutter web dev server runs on a separate port)
# The bundled web app at http://127.0.0.1:8002/ uses same-origin /api — no CORS config needed.
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://127.0.0.1:8002
